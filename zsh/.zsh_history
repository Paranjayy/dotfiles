brew install gnupg
gpg --version
cd root\ and\ config
gpg --import private-key-backup.gpg
nvim public.key
gpg --import public.key
chmod 700 ~/.gnupg\
chmod 600 ~/.gnupg/*
brew install pinentry-mac
mkdir -p ~/.gnupg\
nano ~/.gnupg/gpg-agent.conf
gpgconf --kill gpg-agent
echo "default-key 35A408247C801F80" >> ~/.gnupg/gpg.conf
echo "hello" | gpg --clearsign
gpg --edit-key 35A408247C801F80
gpg --list-secret-keys --keyid-format=long
