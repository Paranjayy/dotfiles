#!/bin/bash\
# 1. Install Homebrew (if not done yet)\
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"\
echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> ~/.zshrc\
eval "$(/opt/homebrew/bin/brew shellenv)"\
\
# 2. Formulae (5 remaining)\
brew install lazydocker pnpm docker htop git-lfs\
\
# 3. Applications (7)\
brew install --cask keka visual-studio-code google-chrome figma discord sketch stats\
\
# 4. Bonus tools (optional)\
brew install btop glow dog dust procs httpie navi tldr lf\

# One-liner to set it up:\
brew install tmux && \\
git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm && \\
cat > ~/.tmux.conf << 'EOF'\
# Theo-inspired tmux config\
set -g default-terminal "screen-256color"\
set -g mouse on\
set -g base-index 1\
setw -g pane-base-index 1\
set -g renumber-windows on\
bind | split-window -h -c "#{pane_current_path}"\
bind - split-window -v -c "#{pane_current_path}"\
\
# Catppuccin colors\
set -g status on\
set -g status-position bottom\
set -g status-style "bg=#1e1e2e,fg=#cdd6f4"\
set -g status-left-length 60\
set -g status-right-length 80\
\
# Left: session + uptime\
set -g status-left "#[bg=#cba6f7,fg=#1e1e2e,bold] #S #[fg=#cba6f4]#[fg=#cdd6f4] #(uptime | sed 's/.*up/up/' | sed 's/,.*//') "\
\
# Window tabs\
setw -g window-status-format "#[bg=#1e1e2e,fg=#6c7086] #I #W "\
setw -g window-status-current-format "#[bg=#89b4fa,fg=#1e1e2e,bold] #I #W "\
\
# Right: CPU + time + date + user@host\
set -g status-right "#[fg=#a6e3a1]#{cpu_percentage}%% #[fg=#6c7086]âƒ´‚ #[fg=#f9e2af]%H:%M #[fg=#6c7086]âƒ´‚ #[fg=#94e2d5]%d %b #[fg=#6c7086]âƒ´‚ #[bg=#f38ba8,fg=#1e1e2e,bold] #U #[bg=#cba6f7,fg=#1e1e2e,bold] #H "\
\
# Plugins\
set -g @plugin 'tmux-plugins/tpm'\
set -g @plugin 'tmux-plugins/tmux-cpu'\
set -g @plugin 'tmux-plugins/tmux-resurrect'\
run '~/.tmux/plugins/tpm/tpm'\
EOF\
\
echo "Done! Run 'tmux', then press Ctrl+b + I to install plugins"\

# If tmux is running, reload config:\
tmux source-file ~/.tmux.conf\
\
# Or restart tmux:\
tmux kill-server && tmux\

